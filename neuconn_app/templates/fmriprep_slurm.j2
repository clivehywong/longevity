#!/bin/bash
#SBATCH --job-name={{ job_name }}
#SBATCH --array=1-{{ num_subjects }}%{{ max_concurrent }}
#SBATCH --partition={{ partition }}
#SBATCH --cpus-per-task={{ cpus }}
#SBATCH --mem={{ memory }}
#SBATCH --time={{ time_limit }}
#SBATCH --output=logs/sub-%a_%j.out
#SBATCH --error=logs/sub-%a_%j.err

# fMRIPrep SLURM submission script
# Generated by NeuConn HPC Workflow Manager
# Subjects: {{ subjects | join(', ') }}

# Initialize module system if available
if [ -f /etc/profile.d/modules.sh ]; then
    source /etc/profile.d/modules.sh
elif [ -f /usr/share/Modules/init/bash ]; then
    source /usr/share/Modules/init/bash
fi

# Load singularity module if available
if command -v module &> /dev/null; then
    module purge
    module load singularity 2>/dev/null || true
fi

# Configuration
BIDS_DIR="{{ remote_bids }}"
OUT_DIR="{{ remote_fmriprep }}"
WORK_DIR="{{ remote_work }}"
IMG="{{ singularity_image }}"
LICENSE="{{ freesurfer_license }}"

# Get subject ID from array task
SUBID=$(sed -n "${SLURM_ARRAY_TASK_ID}p" {{ remote_base }}/sublist.txt)

if [ -z "$SUBID" ]; then
    echo "ERROR: Could not get subject ID for array task ${SLURM_ARRAY_TASK_ID}"
    exit 1
fi

echo "======================================"
echo "Processing subject: ${SUBID}"
echo "Array task: ${SLURM_ARRAY_TASK_ID}"
echo "Job ID: ${SLURM_JOB_ID}"
echo "Node: $(hostname)"
echo "Start time: $(date)"
echo "======================================"

# Create output directories
mkdir -p ${OUT_DIR} ${WORK_DIR} {{ remote_base }}/logs

# Run fMRIPrep
singularity run --cleanenv \
  --bind ${BIDS_DIR}:/data:ro \
  --bind ${OUT_DIR}:/out \
  --bind ${WORK_DIR}:/work \
  --bind ${LICENSE}:/opt/freesurfer/license.txt \
  ${IMG} \
  /data /out participant \
  --participant-label ${SUBID} \
  --fs-license-file /opt/freesurfer/license.txt \
  --nthreads ${SLURM_CPUS_PER_TASK} \
  --mem_mb {{ memory_mb }} \
  --work-dir /work \
  --output-spaces {{ output_spaces | join(' ') }} \
{%- for flag in fmriprep_flags %}
  {{ flag }} \
{%- endfor %}
  --resource-monitor

EXIT_CODE=$?

# fMRIPrep may exit non-zero due to Sentry cleanup or other non-fatal issues.
# Check for the HTML report to determine actual success.
REPORT_FILE="${OUT_DIR}/sub-${SUBID}.html"
if [ ${EXIT_CODE} -ne 0 ] && [ -f "${REPORT_FILE}" ]; then
    echo "WARNING: fMRIPrep exited with code ${EXIT_CODE} but HTML report exists — treating as success"
    EXIT_CODE=0
fi

echo "======================================"
echo "Finished subject: ${SUBID}"
echo "Exit code: ${EXIT_CODE}"
echo "End time: $(date)"
echo "======================================"

exit ${EXIT_CODE}
