#!/bin/bash
#SBATCH --job-name={{ job_name }}
#SBATCH --partition={{ partition }}
#SBATCH --cpus-per-task={{ cpus }}
#SBATCH --mem={{ memory }}
#SBATCH --time={{ time_limit }}
#SBATCH --output={{ remote_base }}/logs/xcpd_{{ pipeline }}_%j.out
#SBATCH --error={{ remote_base }}/logs/xcpd_{{ pipeline }}_%j.err

# XCP-D SLURM submission script
# Generated by NeuConn HPC Workflow Manager
# Pipeline: {{ pipeline }}
# Subjects: {{ participants | join(', ') }}

set -euo pipefail

# Initialize module system if available
if [ -f /etc/profile.d/modules.sh ]; then
    source /etc/profile.d/modules.sh
elif [ -f /usr/share/Modules/init/bash ]; then
    source /usr/share/Modules/init/bash
fi

# Load singularity module if needed
if ! command -v singularity &> /dev/null && command -v module &> /dev/null; then
    module purge
    module load singularity 2>/dev/null || true
fi

if ! command -v singularity &> /dev/null; then
    echo "ERROR: singularity is not available on the compute node." >&2
    exit 1
fi

if [ ! -f {{ singularity_image | tojson }} ]; then
    echo "ERROR: XCP-D image not found at {{ singularity_image }}." >&2
    exit 1
fi

{% if fs_license %}
if [ ! -f {{ fs_license | tojson }} ]; then
    echo "ERROR: FreeSurfer license not found at {{ fs_license }}." >&2
    exit 1
fi
{% endif %}

echo "======================================"
echo "XCP-D {{ pipeline | upper }} pipeline"
echo "Job ID: ${SLURM_JOB_ID}"
echo "Node: $(hostname)"
echo "Start time: $(date)"
echo "======================================"

# Create output directories
mkdir -p {{ remote_output }} {{ remote_work }} {{ work_dir }} {{ remote_base }}/logs

# Run XCP-D via Singularity
singularity run \
{%- for mount in bind_mounts %}
  -B {{ mount }}:{{ mount }} \
{%- endfor %}
  {{ singularity_image }} \
  {{ xcpd_args }}

EXIT_CODE=$?

echo "======================================"
echo "XCP-D {{ pipeline | upper }} finished"
echo "Exit code: ${EXIT_CODE}"
echo "End time: $(date)"
echo "======================================"

exit ${EXIT_CODE}
